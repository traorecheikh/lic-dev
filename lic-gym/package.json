{
  "name": "gym-app",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @gym/api prisma:generate",
    "db:migrate": "pnpm --filter @gym/api prisma:migrate",
    "db:seed": "pnpm --filter @gym/api prisma:seed"
  },
  "devDependencies": {
    "turbo": "^2.9.3",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0"
  }
}
