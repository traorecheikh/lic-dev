{
  "kind": "collectionType",
  "collectionName": "offres",
  "info": {
    "singularName": "offre",
    "pluralName": "offres",
    "displayName": "Offre",
    "description": "Offres d'emploi publiées sur le site"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "titre": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titre"
    },
    "localisation": {
      "type": "string"
    },
    "departement": {
      "type": "string"
    },
    "type_emploi": {
      "type": "enumeration",
      "enum": ["Temps plein", "Consultant", "Temps partiel", "Stage"],
      "default": "Temps plein"
    },
    "statut": {
      "type": "enumeration",
      "enum": ["ouvert", "ferme"],
      "default": "ouvert"
    },
    "description": {
      "type": "richtext"
    },
    "responsabilites": {
      "type": "richtext"
    },
    "competences": {
      "type": "richtext"
    },
    "agreable_avoir": {
      "type": "richtext"
    },
    "points_forts": {
      "type": "richtext"
    },
    "offres_entreprise": {
      "type": "richtext"
    },
    "processus": {
      "type": "richtext"
    },
    "delai_reponse": {
      "type": "string"
    },
    "jours_offre": {
      "type": "integer"
    }
  }
}
